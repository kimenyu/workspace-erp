# ============================================================
#  workspace-erp — root .gitignore
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnpm-debug.log

# ── Build outputs ────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# ── Environment & secrets ────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
# keep the example committed
!.env.example

# ── Prisma ───────────────────────────────────────────────────
# generated client (re-created by prisma generate)
apps/api/node_modules/.prisma/
apps/api/src/generated/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/

# ── Docker ───────────────────────────────────────────────────
# ignore local override files but keep the main compose
infra/docker-compose.override.yml

# ── Misc ─────────────────────────────────────────────────────
*.local
.cache/
tmp/
temp/


