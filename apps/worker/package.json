{
    "name": "@workspace-erp/worker",
    "private": true,
    "scripts": {
        "prisma:generate": "prisma generate --schema ../api/prisma/schema.prisma",
        "dev": "pnpm prisma:generate && ts-node-dev --respawn --transpile-only src/main.ts",
        "build": "pnpm prisma:generate && tsc -p tsconfig.json",
        "start": "node dist/main.js"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "bullmq": "^5.70.2",
        "dotenv": "^17.3.1",
        "ioredis": "^5.10.0",
        "nodemailer": "^8.0.1",
        "pdfkit": "^0.17.2",
        "pg": "^8.20.0",
        "prisma": "^7.4.2"
    },
    "devDependencies": {
        "@types/node": "^25.3.3",
        "@types/nodemailer": "^7.0.11",
        "@types/pdfkit": "^0.17.5",
        "@types/pg": "^8.18.0",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.9.3"
    }
}